# =============================================
# Smart-Trade API Keys Configuration
# =============================================
# Copy this file to .env and fill in your API keys.
# NEVER commit the .env file to version control.

# Financial Modeling Prep (company financials)
# Sign up at: https://financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_api_key_here

# FRED - Federal Reserve Economic Data (CPI, GDP, Interest Rate, etc.)
# Sign up at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Alpha Vantage (GDP, Unemployment economic indicators)
# Sign up at: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key_here

# News API (optional - for future sentiment analysis)
# Sign up at: https://newsapi.org
NEWS_API_KEY=your_news_api_key_here
